<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" width="800" height="600">
  <defs>
    <linearGradient id="warm3" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#4E2239"/>
      <stop offset="1" stop-color="#2C1220"/>
    </linearGradient>
    <radialGradient id="halo3" cx="0.5" cy="0.45" r="0.55">
      <stop offset="0" stop-color="#C9A15B" stop-opacity="0.6"/>
      <stop offset="1" stop-color="#C9A15B" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="800" height="600" fill="url(#warm3)"/>
  <circle cx="400" cy="300" r="280" fill="url(#halo3)"/>
  <!-- duas silhuetas de perfil, testas quase encostadas -->
  <g fill="#160812">
    <!-- ela (esquerda) -->
    <path d="M360 230
             q-8 -48 -50 -60
             q-48 -12 -74 26
             q-16 24 -8 56
             q6 22 24 30
             q-8 18 -4 40
             l10 58
             q34 10 70 4
             l30 -8 z"/>
    <path d="M150 470
             q6 -74 74 -92
             q60 -12 96 10
             l20 12 l0 168 l-190 0 z"/>
    <!-- ele (direita) -->
    <path d="M440 230
             q8 -48 50 -60
             q48 -12 74 26
             q16 24 8 56
             q-6 22 -24 30
             q8 18 4 40
             l-10 58
             q-34 10 -70 4
             l-30 -8 z"/>
    <path d="M650 470
             q-6 -74 -74 -92
             q-60 -12 -96 10
             l-20 12 l0 168 l190 0 z"/>
  </g>
  <!-- brilho dourado no ponto de encontro das testas -->
  <circle cx="400" cy="250" r="40" fill="#C9A15B" opacity="0.18"/>
  <path d="M360 230 q40 -24 80 0" fill="none" stroke="#C9A15B" stroke-width="2" opacity="0.4"/>
</svg>